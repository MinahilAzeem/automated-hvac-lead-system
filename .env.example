# ==========================================
# ⚡ AIRTABLE CONFIGURATION
# ==========================================
# Generate your Personal Access Token (PAT) at: https://airtable.com/create/tokens
# Required Scopes: schema.bases:read, data.records:write
AIRTABLE_PAT=pat_Your_Token_Goes_Here

# Your Base ID (Found in the URL, always starts with 'app')
AIRTABLE_BASE_ID=app_Your_Base_ID_Here

# ==========================================
# 🧠 AI AGENT CONFIGURATION
# ==========================================
# Provide the API key for the LLM driving the triage agent
OPENAI_API_KEY=sk-proj-Your_API_Key_Here
